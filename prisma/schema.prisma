generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  BRAND
  CREATOR
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  BANNED
  PENDING_VERIFICATION
}

enum CampaignStatus {
  DRAFT
  PENDING_REVIEW
  NEEDS_CHANGES
  PENDING_FUNDING
  SCHEDULED
  ACTIVE
  PAUSED
  BUDGET_LOW
  BUDGET_EXHAUSTED
  COMPLETED
  CANCELLED
  REJECTED
  ARCHIVED
}

enum Platform {
  TIKTOK
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  X
  THREADS
}

enum Currency {
  IQD
  USD
}

enum LedgerDirection {
  DEBIT
  CREDIT
}

enum SocialAccountStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum BrandVerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CampaignCategory {
  PRODUCT
  BEAUTY
  FOOD
  FASHION
  TECH
  ENTERTAINMENT
  GAMING
  OTHER
}

enum SubmissionStatus {
  SUBMITTED
  UNDER_REVIEW
  REVISION_REQUESTED
  APPROVED
  REJECTED
}

model User {
  id           String     @id @default(cuid())
  email        String?    @unique
  phone        String?    @unique
  passwordHash String?
  fullName     String
  role         UserRole
  status       UserStatus @default(PENDING_VERIFICATION)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  creatorProfile              CreatorProfile?
  brandMembers                BrandMember[]
  wallets                     Wallet[]
  capturedSnapshots           MetricsSnapshot[]
  deposits                    Deposit[]
  payouts                     PayoutRequest[]
  fraudSignals                FraudSignal[]
  openedDisputes              Dispute[]                @relation("OpenedDisputes")
  resolvedDisputes            Dispute[]                @relation("ResolvedDisputes")
  disputeMessages             DisputeMessage[]
  disputeAttachments          DisputeAttachment[]      @relation("DisputeAttachments")
  trustScoreEvents            TrustScoreEvent[]
  notifications               Notification[]
  notificationPreferences     NotificationPreference[]
  auditLogs                   AuditLog[]
  passwordResetTokens         PasswordResetToken[]
  following                   UserFollow[]             @relation("UserFollowing")
  followers                   UserFollow[]             @relation("UserFollowers")
  communityPosts              CommunityPost[]
  communityComments           CommunityComment[]
  communityLikes              CommunityLike[]
  communitySaves              CommunitySave[]
  communityShares             CommunityShare[]
  communityReports            CommunityReport[]        @relation("CommunityReportReporter")
  reviewedCommunityReports    CommunityReport[]        @relation("CommunityReportReviewer")
  blocksInitiated             UserBlock[]              @relation("UserBlocker")
  blocksReceived              UserBlock[]              @relation("UserBlocked")
  mutesInitiated              UserMute[]               @relation("UserMuter")
  mutesReceived               UserMute[]               @relation("UserMuted")
  privacySettings             UserPrivacySettings?
  conversationsCreated        Conversation[]           @relation("ConversationCreator")
  conversationMessages        ConversationMessage[]
  conversationReports         ConversationReport[]     @relation("ConversationReportReporter")
  reviewedConversationReports ConversationReport[]     @relation("ConversationReportReviewer")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model CreatorProfile {
  id                String             @id @default(cuid())
  userId            String             @unique
  username          String?            @unique
  bio               String?
  avatarUrl         String?
  coverUrl          String?
  country           String             @default("IQ")
  governorate       String?
  contentCategories CampaignCategory[] @default([])
  languages         String[]           @default([])
  isProfilePublic   Boolean            @default(true)
  trustScore        Int                @default(50)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  user             User                   @relation(fields: [userId], references: [id])
  memberships      CampaignMembership[]
  conversations    Conversation[]
  socialAccounts   SocialAccount[]
  portfolioItems   CreatorPortfolioItem[]
  trustScoreEvents TrustScoreEvent[]
}

model CreatorPortfolioItem {
  id               String   @id @default(cuid())
  creatorProfileId String
  title            String
  description      String?
  platform         Platform
  projectUrl       String
  thumbnailUrl     String?
  sortOrder        Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@unique([creatorProfileId, projectUrl])
  @@index([creatorProfileId, sortOrder, createdAt])
}

model UserFollow {
  id             String   @id @default(cuid())
  followerUserId String
  followedUserId String
  createdAt      DateTime @default(now())

  follower User @relation("UserFollowing", fields: [followerUserId], references: [id], onDelete: Cascade)
  followed User @relation("UserFollowers", fields: [followedUserId], references: [id], onDelete: Cascade)

  @@unique([followerUserId, followedUserId])
  @@index([followerUserId, createdAt])
  @@index([followedUserId, createdAt])
}

enum CommunityPostStatus {
  ACTIVE
  REMOVED
}

enum CommunityCommentStatus {
  ACTIVE
  REMOVED
}

enum CommunityReportStatus {
  OPEN
  REVIEWED
  DISMISSED
  ACTIONED
}

enum CommunityReportReason {
  SPAM
  HARASSMENT
  HATE
  MISINFORMATION
  COPYRIGHT
  OTHER
}

enum MessagePermission {
  CAMPAIGN_CONTACTS
  FOLLOWING
  NOBODY
}

model CommunityPost {
  id              String              @id @default(cuid())
  authorId        String
  body            String?
  imageUrl        String?
  linkUrl         String?
  linkTitle       String?
  linkDescription String?
  linkImageUrl    String?
  status          CommunityPostStatus @default(ACTIVE)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  author   User                 @relation(fields: [authorId], references: [id], onDelete: Cascade)
  images   CommunityPostImage[]
  comments CommunityComment[]
  likes    CommunityLike[]
  saves    CommunitySave[]
  shares   CommunityShare[]
  reports  CommunityReport[]

  @@index([status, createdAt])
  @@index([authorId, createdAt])
}

model CommunityPostImage {
  id        String   @id @default(cuid())
  postId    String
  url       String
  sortOrder Int
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, sortOrder])
  @@index([postId])
}

model CommunityComment {
  id        String                 @id @default(cuid())
  postId    String
  authorId  String
  parentId  String?
  body      String
  status    CommunityCommentStatus @default(ACTIVE)
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  post    CommunityPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  author  User               @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent  CommunityComment?  @relation("CommunityCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies CommunityComment[] @relation("CommunityCommentReplies")
  reports CommunityReport[]

  @@index([postId, status, createdAt])
  @@index([authorId, createdAt])
  @@index([parentId, status, createdAt])
}

model CommunityLike {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model CommunitySave {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model CommunityShare {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
}

model CommunityReport {
  id           String                @id @default(cuid())
  reporterId   String
  postId       String?
  commentId    String?
  reason       CommunityReportReason
  details      String?
  status       CommunityReportStatus @default(OPEN)
  reviewNote   String?
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  reporter User              @relation("CommunityReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer User?             @relation("CommunityReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  post     CommunityPost?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment  CommunityComment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([reporterId, createdAt])
  @@index([postId])
  @@index([commentId])
}

model UserBlock {
  id            String   @id @default(cuid())
  blockerUserId String
  blockedUserId String
  createdAt     DateTime @default(now())

  blocker User @relation("UserBlocker", fields: [blockerUserId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlocked", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([blockerUserId, blockedUserId])
  @@index([blockedUserId, createdAt])
}

model UserMute {
  id          String   @id @default(cuid())
  muterUserId String
  mutedUserId String
  createdAt   DateTime @default(now())

  muter User @relation("UserMuter", fields: [muterUserId], references: [id], onDelete: Cascade)
  muted User @relation("UserMuted", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@unique([muterUserId, mutedUserId])
  @@index([mutedUserId, createdAt])
}

model UserPrivacySettings {
  id                String            @id @default(cuid())
  userId            String            @unique
  messagePermission MessagePermission @default(CAMPAIGN_CONTACTS)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BrandProfile {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  description String?
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  members       BrandMember[]
  campaigns     Campaign[]
  verifications BrandVerification[]
}

model BrandMember {
  id        String   @id @default(cuid())
  userId    String
  brandId   String
  role      String   @default("OWNER")
  createdAt DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id])
  brand BrandProfile @relation(fields: [brandId], references: [id])

  @@unique([userId, brandId])
}

model Campaign {
  id               String           @id @default(cuid())
  brandId          String
  title            String
  summary          String
  terms            String
  category         CampaignCategory @default(OTHER)
  thumbnailUrl     String?
  minTrustScore    Int              @default(0)
  status           CampaignStatus   @default(DRAFT)
  currency         Currency         @default(IQD)
  totalBudget      BigInt
  reservedBudget   BigInt           @default(0)
  startsAt         DateTime?
  endsAt           DateTime?
  reviewNote       String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  brand         BrandProfile           @relation(fields: [brandId], references: [id])
  rates         CampaignPlatformRate[]
  assets        CampaignAsset[]
  memberships   CampaignMembership[]
  conversations Conversation[]

  @@index([status, startsAt, endsAt])
  @@index([brandId])
  @@index([category])
}

model CampaignAsset {
  id         String   @id @default(cuid())
  campaignId String
  url        String
  label      String
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@index([campaignId])
}

model CampaignPlatformRate {
  id                    String   @id @default(cuid())
  campaignId            String
  platform              Platform
  cpmMinorUnits         BigInt
  minimumQualifiedViews BigInt   @default(0)
  maximumReward         BigInt
  createdAt             DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id])

  @@unique([campaignId, platform])
}

model CampaignMembership {
  id               String   @id @default(cuid())
  campaignId       String
  creatorProfileId String
  termsSnapshot    Json
  acceptedAt       DateTime @default(now())
  createdAt        DateTime @default(now())

  campaign       Campaign       @relation(fields: [campaignId], references: [id])
  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id])
  submissions    Submission[]

  @@unique([campaignId, creatorProfileId])
}

model Conversation {
  id               String   @id @default(cuid())
  campaignId       String
  creatorProfileId String
  createdByUserId  String
  lastMessageAt    DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  campaign       Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  creatorProfile CreatorProfile        @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  createdBy      User                  @relation("ConversationCreator", fields: [createdByUserId], references: [id])
  messages       ConversationMessage[]
  reports        ConversationReport[]

  @@unique([campaignId, creatorProfileId])
  @@index([campaignId, lastMessageAt])
  @@index([creatorProfileId, lastMessageAt])
}

model ConversationMessage {
  id             String    @id @default(cuid())
  conversationId String
  senderUserId   String
  body           String
  readAt         DateTime?
  removedAt      DateTime?
  createdAt      DateTime  @default(now())

  conversation Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User                 @relation(fields: [senderUserId], references: [id], onDelete: Cascade)
  reports      ConversationReport[]

  @@index([conversationId, createdAt])
  @@index([senderUserId, createdAt])
}

model ConversationReport {
  id             String                @id @default(cuid())
  conversationId String
  messageId      String?
  reporterId     String
  reason         CommunityReportReason
  details        String?
  status         CommunityReportStatus @default(OPEN)
  reviewNote     String?
  reviewedById   String?
  reviewedAt     DateTime?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  conversation Conversation         @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      ConversationMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  reporter     User                 @relation("ConversationReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reviewer     User?                @relation("ConversationReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([conversationId, createdAt])
  @@index([reporterId, createdAt])
}

model Submission {
  id                   String           @id @default(cuid())
  campaignMembershipId String
  socialAccountId      String
  platform             Platform
  postUrl              String
  platformPostId       String
  status               SubmissionStatus @default(SUBMITTED)
  rejectionReason      String?
  reviewNote           String?
  reviewedByUserId     String?
  reviewedAt           DateTime?
  submittedAt          DateTime         @default(now())
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  campaignMembership CampaignMembership @relation(fields: [campaignMembershipId], references: [id])
  socialAccount      SocialAccount      @relation(fields: [socialAccountId], references: [id])
  metricsSnapshots   MetricsSnapshot[]
  earnings           EarningAccrual[]
  fraudSignals       FraudSignal[]
  fraudAssessment    FraudAssessment?
  disputes           Dispute[]

  @@unique([platform, platformPostId])
  @@index([campaignMembershipId, status])
}

model FinancialAccount {
  id        String   @id @default(cuid())
  name      String
  currency  Currency @default(IQD)
  createdAt DateTime @default(now())

  walletEntries Wallet[]
  entries       LedgerEntry[]
}

model Wallet {
  id                 String   @id @default(cuid())
  userId             String
  financialAccountId String   @unique
  currency           Currency @default(IQD)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user             User             @relation(fields: [userId], references: [id])
  financialAccount FinancialAccount @relation(fields: [financialAccountId], references: [id])

  @@unique([userId, currency])
}

model LedgerTransaction {
  id             String   @id @default(cuid())
  idempotencyKey String   @unique
  type           String
  currency       Currency
  status         String
  description    String?
  createdAt      DateTime @default(now())

  entries       LedgerEntry[]
  deposit       Deposit?
  payoutRequest PayoutRequest?
}

model LedgerEntry {
  id            String          @id @default(cuid())
  transactionId String
  accountId     String
  direction     LedgerDirection
  amount        BigInt
  createdAt     DateTime        @default(now())

  transaction LedgerTransaction @relation(fields: [transactionId], references: [id])
  account     FinancialAccount  @relation(fields: [accountId], references: [id])

  @@index([accountId, createdAt])
}

model SocialAccount {
  id               String              @id @default(cuid())
  creatorProfileId String
  platform         Platform
  handle           String
  profileUrl       String
  status           SocialAccountStatus @default(PENDING)
  rejectionReason  String?
  verifiedAt       DateTime?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id])
  submissions    Submission[]

  @@unique([platform, handle])
  @@index([creatorProfileId])
}

model BrandVerification {
  id               String                  @id @default(cuid())
  brandId          String
  status           BrandVerificationStatus @default(PENDING)
  note             String?
  reviewedByUserId String?
  requestedAt      DateTime                @default(now())
  reviewedAt       DateTime?

  brand BrandProfile @relation(fields: [brandId], references: [id])

  @@index([brandId, status])
}

enum EarningStatus {
  ESTIMATED
  PENDING_VERIFICATION
  HELD
  AVAILABLE
  PAID
  REVERSED
}

model MetricsSnapshot {
  id                     String   @id @default(cuid())
  submissionId           String
  observedViews          BigInt
  qualifiedViews         BigInt
  disqualifiedViews      BigInt   @default(0)
  disqualificationReason String?
  source                 String   @default("MANUAL_ADMIN")
  capturedByUserId       String?
  capturedAt             DateTime @default(now())
  createdAt              DateTime @default(now())

  submission Submission       @relation(fields: [submissionId], references: [id])
  capturedBy User?            @relation(fields: [capturedByUserId], references: [id])
  earnings   EarningAccrual[]

  @@index([submissionId])
}

model EarningAccrual {
  id                String        @id @default(cuid())
  submissionId      String
  metricsSnapshotId String?
  amount            BigInt
  currency          Currency      @default(IQD)
  status            EarningStatus @default(PENDING_VERIFICATION)
  heldUntil         DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  submission      Submission       @relation(fields: [submissionId], references: [id])
  metricsSnapshot MetricsSnapshot? @relation(fields: [metricsSnapshotId], references: [id])

  @@index([submissionId])
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
}

model Deposit {
  id                  String        @id @default(cuid())
  userId              String
  amount              BigInt
  currency            Currency      @default(IQD)
  status              DepositStatus @default(PENDING)
  referenceNumber     String?
  note                String?
  reviewedByUserId    String?
  ledgerTransactionId String?       @unique
  reviewedAt          DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  ledgerTransaction LedgerTransaction? @relation(fields: [ledgerTransactionId], references: [id])

  @@index([userId, status])
}

model PayoutRequest {
  id                  String       @id @default(cuid())
  userId              String
  amount              BigInt
  currency            Currency     @default(IQD)
  status              PayoutStatus @default(PENDING)
  payoutMethod        String
  recipientDetails    String
  referenceNumber     String?
  note                String?
  reviewedByUserId    String?
  ledgerTransactionId String?      @unique
  reviewedAt          DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  user              User               @relation(fields: [userId], references: [id])
  ledgerTransaction LedgerTransaction? @relation(fields: [ledgerTransactionId], references: [id])

  @@index([userId, status])
}

enum FraudSignalKind {
  VIEW_SPIKE
  HIGH_DISQUALIFIED_RATIO
  MANUAL_ADMIN_FLAG
  DUPLICATE_CONTENT_SUSPECTED
  PAID_PROMOTION_SUSPECTED
  ACCOUNT_PRIVACY_CHANGED
  POST_REMOVED
  OTHER
}

enum FraudReviewStatus {
  OPEN
  UNDER_REVIEW
  CLEARED
  CONFIRMED
}

enum FraudRiskLevel {
  LOW
  MEDIUM
  HIGH
}

model FraudSignal {
  id              String          @id @default(cuid())
  submissionId    String
  kind            FraudSignalKind
  scoreImpact     Int
  note            String?
  createdByUserId String?
  createdAt       DateTime        @default(now())

  submission    Submission @relation(fields: [submissionId], references: [id])
  createdByUser User?      @relation(fields: [createdByUserId], references: [id])

  @@index([submissionId, kind])
  @@index([createdAt])
}

model FraudAssessment {
  id               String            @id @default(cuid())
  submissionId     String            @unique
  fraudScore       Int               @default(0)
  riskLevel        FraudRiskLevel    @default(LOW)
  status           FraudReviewStatus @default(OPEN)
  reviewNote       String?
  reviewedByUserId String?
  reviewedAt       DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  submission Submission @relation(fields: [submissionId], references: [id])

  @@index([status, riskLevel])
}

enum TrustScoreEventReason {
  FRAUD_CONFIRMED
  FRAUD_CLEARED
  DISPUTE_RESOLVED_CREATOR
  DISPUTE_RESOLVED_BRAND
  ADMIN_ADJUSTMENT
}

model TrustScoreEvent {
  id               String                @id @default(cuid())
  creatorProfileId String
  userId           String
  delta            Int
  reason           TrustScoreEventReason
  note             String?
  createdAt        DateTime              @default(now())

  creatorProfile CreatorProfile @relation(fields: [creatorProfileId], references: [id])
  user           User           @relation(fields: [userId], references: [id])

  @@index([creatorProfileId, createdAt])
}

enum DisputeStatus {
  OPEN
  AWAITING_CREATOR
  AWAITING_BRAND
  UNDER_ADMIN_REVIEW
  RESOLVED_CREATOR
  RESOLVED_BRAND
  PARTIAL_RESOLUTION
  CLOSED
}

enum DisputeReason {
  SUBMISSION_REJECTION
  QUALIFIED_VIEWS
  DISQUALIFICATION
  EARNINGS
  PAYOUT
  BRAND_MISUSE
  FRAUD_CLAIM
  OTHER
}

model Dispute {
  id               String        @id @default(cuid())
  submissionId     String
  openedByUserId   String
  status           DisputeStatus @default(OPEN)
  reason           DisputeReason
  title            String
  description      String
  resolutionNote   String?
  resolvedByUserId String?
  resolvedAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  submission  Submission          @relation(fields: [submissionId], references: [id])
  openedBy    User                @relation("OpenedDisputes", fields: [openedByUserId], references: [id])
  resolvedBy  User?               @relation("ResolvedDisputes", fields: [resolvedByUserId], references: [id])
  messages    DisputeMessage[]
  attachments DisputeAttachment[]

  @@index([submissionId, status])
  @@index([openedByUserId, status])
}

// أدلة النزاعات: تُخزن داخل قاعدة البيانات (bytea) بحدود صارمة في MVP —
// لا تخزين خارجي قبل توفر credentials؛ مسار الترقية لاحقاً: Supabase Storage.
model DisputeAttachment {
  id               String   @id @default(cuid())
  disputeId        String
  uploadedByUserId String
  fileName         String
  mimeType         String
  sizeBytes        Int
  data             Bytes
  createdAt        DateTime @default(now())

  dispute    Dispute @relation(fields: [disputeId], references: [id])
  uploadedBy User    @relation("DisputeAttachments", fields: [uploadedByUserId], references: [id])

  @@index([disputeId, createdAt])
}

model DisputeMessage {
  id           String   @id @default(cuid())
  disputeId    String
  senderUserId String
  body         String
  createdAt    DateTime @default(now())

  dispute Dispute @relation(fields: [disputeId], references: [id])
  sender  User    @relation(fields: [senderUserId], references: [id])

  @@index([disputeId, createdAt])
}

enum NotificationType {
  CAMPAIGN_APPROVED
  CAMPAIGN_NEEDS_CHANGES
  CAMPAIGN_REJECTED
  SUBMISSION_REVIEWED
  DEPOSIT_REVIEWED
  PAYOUT_REVIEWED
  DISPUTE_UPDATED
  FRAUD_FLAGGED
  FOLLOW_RECEIVED
  COMMUNITY_ACTIVITY
  MESSAGE_RECEIVED
  GENERIC
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  link      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, readAt, createdAt])
}

// Per-user, per-category opt-out. Absence of a row means "enabled" (the
// default before this feature existed), so NotificationService.notify must
// treat a missing row as enabled=true rather than creating rows eagerly.
model NotificationPreference {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  enabled   Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, type])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actorEmail String?
  action     String
  targetType String
  targetId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  actor User? @relation(fields: [actorId], references: [id])

  @@index([targetType, targetId])
  @@index([createdAt])
}
